# --- HELPER FUNCTIONS ---
PID_FILE = "running_process.pid"

def clean_json_text(text):
    """Membersihkan output AI dari markdown ```json dan ```"""
    text = text.strip()
    if text.startswith("```json"):
        text = text[7:]
    if text.startswith("```"):
        text = text[3:]
    if text.endswith("```"):
        text = text[:-3]
    return text.strip()

def save_pid(pid):
    """Menyimpan ID proses yang sedang berjalan ke file"""
    with open(PID_FILE, "w") as f:
        f.write(str(pid))

def get_pid():
    """Membaca ID proses dari file"""
    if os.path.exists(PID_FILE):
        with open(PID_FILE, "r") as f:
            try:
                return int(f.read().strip())
            except:
                return None
    return None

def clear_pid():
    """Menghapus file PID setelah proses selesai"""
    if os.path.exists(PID_FILE):
        os.remove(PID_FILE)

def kill_running_process():
    """Membunuh proses yang tersimpan di PID file"""
    pid = get_pid()
    if pid:
        try:
            # Mengirim sinyal SIGTERM (Terminate)
            os.kill(pid, signal.SIGTERM)
            st.toast(f"🛑 Proses (PID: {pid}) berhasil dihentikan paksa!", icon="💀")
        except ProcessLookupError:
            st.warning("Proses sudah tidak ada (mungkin sudah selesai).")
        except Exception as e:
            st.error(f"Gagal menghentikan proses: {e}")
        finally:
            clear_pid()
            if 'stop_btn_container' in locals():
                stop_btn_container.empty()
            #time.sleep(1)
            #st.rerun()
    else:
        st.info("Tidak ada proses yang tercatat sedang berjalan.")

def pick_from_json_field(data: dict, key: str, fallback=""):
    """
    Ambil value dari JSON:
    - kalau string -> return string
    - kalau list -> pilih random
    - kalau tidak ada -> fallback
    """
    val = data.get(key, fallback)
    if isinstance(val, list):
        val = random.choice(val) if val else fallback
    if val is None:
        val = fallback
    return str(val).strip()


def get_topics():
    """Mendapatkan list folder topic di dalam 'contents/'"""
    contents_path = Path("contents")
    if not contents_path.exists():
        os.makedirs(contents_path)
    return [d.name for d in contents_path.iterdir() if d.is_dir()]

def get_latest_long_video():
    """Ambil file mp4 terbaru dari folder results (Long Video output)."""
    res_dir = Path("results")
    if not res_dir.exists():
        return None

    files = list(res_dir.glob("*.mp4"))
    if not files:
        return None

    return max(files, key=os.path.getmtime)

def get_latest_video(topic):
    """Mencari file mp4 terakhir yang dimodifikasi di folder out/topic"""
    out_dir = Path(f"out/{topic}")
    if not out_dir.exists():
        return None
    
    files = list(out_dir.glob("*.mp4"))
    if not files:
        return None
    
    # Sort by modification time (terbaru di paling akhir)
    latest_file = max(files, key=os.path.getmtime)
    return latest_file

def run_script(cmd_list):
    """Menjalankan main.py sebagai subprocess dan streaming outputnya"""
    process = subprocess.Popen(
        cmd_list,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
        universal_newlines=True
    )
    
    return process

# --- SIDEBAR: SETTINGS ---
with st.sidebar:
