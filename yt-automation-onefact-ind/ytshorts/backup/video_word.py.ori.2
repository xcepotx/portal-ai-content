]

CTA_TEMPLATES = [
    ("LIKE KALO BARU TAU!", "SAVE BIAR GAK LUPA"),
    ("SETUJU / NGGAK?", "TULIS DI KOMEN"),
    ("MAU TOPIK APA LAGI?", "REQUEST DI KOMEN"),
    ("BAGIKAN KE TEMENMU!", "BIAR MEREKA JUGA TAU"),
    ("KOMEN: ‘BARU TAU’", "KALO INI BIKIN KAGET"),
    ("RATE 1–10!", "SEBERAPA KEREN MENURUTMU?"),
]

_LAST_HOOK_IDX = None
_LAST_CTA_IDX = None

def _pick_non_repeat(rng: random.Random, items, last_idx_holder_name: str):
    global _LAST_HOOK_IDX, _LAST_CTA_IDX

    n = len(items)
    if n == 0:
        return None

    if last_idx_holder_name == "hook":
        last = _LAST_HOOK_IDX
    else:
        last = _LAST_CTA_IDX

    if n == 1:
        idx = 0
    else:
        idx = rng.randrange(n)
        if last is not None and idx == last:
            idx = (idx + 1) % n

    if last_idx_holder_name == "hook":
        _LAST_HOOK_IDX = idx
    else:
        _LAST_CTA_IDX = idx

    return items[idx]

# =========================
# MAIN BUILDER (FAST)
# =========================
def build_onefact_video_word_captions(
    bg_paths: List[str],
    lines: List[str],
    tts_files: List[str],
    out_dir: str,
    out_mp4: str,
) -> str:
    """
    1 content (list of lines) => 1 final mp4
    - multi background (bg_paths) dipakai bergantian per line
    - Ken Burns super halus (make_kenburns_clip)
    - caption karaoke per kata (PNG overlay), max 3 kata tampil
    - timing kata heuristik agar lebih nempel TTS
    - BUGFIX penting: background TIDAK restart tiap kata (pakai subclip timeline)
    """
    os.makedirs(out_dir, exist_ok=True)
    cap_dir = os.path.join(out_dir, "_wordcaps")
    os.makedirs(cap_dir, exist_ok=True)

    overlay_dir = os.path.join(out_dir, "_overlays")
    os.makedirs(overlay_dir, exist_ok=True)

    HOOK_DUR = 1.2
    CTA_DUR  = 1.4


    segments: List = []

    # helper subclip kompatibel moviepy v2
    def _sub(clip, t0: float, t1: float):
        if hasattr(clip, "subclip"):
            return clip.subclip(t0, t1)
        return clip.subclipped(t0, t1)

    for i, line in enumerate(lines):
        audio_path = tts_files[i]
        dur_ff = max(audio_duration_seconds(audio_path), 1.2)

        voice = AudioFileClip(audio_path)
        voice_dur = float(voice.duration or 0.0)
        dur = max(1.2, voice_dur)

        # dur video ikuti durasi audio (paling aman, anti error & anti black)
        # dur = max(1.2, voice_dur, dur_ff)
        dur = max(1.2, voice_dur)

        # buffer kecil hanya untuk VIDEO, bukan untuk subclip audio
        dur_video = dur + 0.10

        # pilih bg bergantian per line
        bg_src = bg_paths[i % len(bg_paths)]

        # Ken Burns halus (per-frame PIL)
        bg_full = make_kenburns_clip(
            bg_src,
            dur=dur_video,
            out_size=(720, 1280),
            zoom_max=0.10,   # bisa turunin 0.08 kalau mau lebih kalem
            pan_x=55.0,
            pan_y=35.0,
            rot_deg_max=0.45
        )

        words = split_words(line)
        if not words:
            # audio jangan dipotong melebihi voice.duration
            voice_cut = _sub_audio(voice, 0, dur)
            # clip durasi ikut audio (bukan dur_video)
            clip = clip.with_audio(voice_cut).with_duration(dur)
            #clip = bg_full.with_audio(voice_cut).with_duration(float(dur))
            segments.append(clip)
            continue

        durs = word_durations(words, dur)

        word_clips: List = []
        so_far: List[str] = []
        t_cursor = 0.0

        for w_idx, w in enumerate(words):
            so_far.append(w)

            ov_path = os.path.join(cap_dir, f"cap_{i:02d}_{w_idx:03d}.png")
            render_word_overlay(so_far, w, ov_path)

            seg_dur = float(durs[w_idx])
            t0 = float(t_cursor)
            t1 = float(min(dur, t_cursor + seg_dur))

            # background ikut timeline (no reset)
            seg_dur = max(0.001, t1 - t0)
            bg_seg = _sub(bg_full, t0, t1)

            ov = ImageClip(ov_path).with_duration(seg_dur)

            # fade-in cepat biar enak
            fade_in = min(0.08, seg_dur * 0.35)

            def opacity(t: float) -> float:
                return min(1.0, max(0.0, t / max(0.001, fade_in)))

            try:
                ov = ov.with_opacity(opacity)
            except Exception:
                pass

            sub = CompositeVideoClip([bg_seg, ov]).with_duration(seg_dur)
            word_clips.append(sub)

            t_cursor = t1

        clip = concatenate_videoclips(word_clips, method="compose")

        # potong audio tepat sepanjang dur (biar match video)
        voice_cut = _sub_audio(voice, 0, float(dur))
        clip = clip.with_audio(voice_cut).with_duration(float(dur))

        segments.append(clip)

    # =========================
    # HOOK overlay on FIRST segment (no extra segment)
    # =========================
    HOOK_DUR = 1.2

    if segments:
        hook_title, hook_sub = auto_hook_from_doc(lines=lines, topic="FAKTA CEPAT")
        hook_png = os.path.join(overlay_dir, "hook.png")
        render_hook_overlay(hook_png, 720, 1280, hook_title, hook_sub)

        first = segments[0]

        # pakai RGBA biar transparansi aman (kalau kamu sudah punya rgba_clip)
        try:
            hook_ov = rgba_clip(hook_png, HOOK_DUR)
        except Exception:
            hook_ov = ImageClip(hook_png).with_duration(HOOK_DUR)

        # posisi & animasi kecil
        #hook_ov = hook_ov.with_position(lambda t: ("center", int(40 + 25 * max(0, 1 - t * 3))))
        jitter = random.randint(-10, 10)  # sekali per video, bukan tiap frame
        hook_ov = hook_ov.with_position(lambda t: ("center", int(40 + jitter + 25 * max(0, 1 - t * 3))))

        # fade-in yang aman (JANGAN _fadein_masked)
        fade_dur = 0.25
        def hook_frame(t):
            return hook_ov.get_frame(t)

        # set start=0 (default) & durasi HOOK
        try:
            hook_ov = hook_ov.with_start(0)
        except Exception:
            hook_ov = hook_ov.set_start(0)

        # Composite: hook overlay di atas segmen pertama
        segments[0] = CompositeVideoClip([first, hook_ov]).with_duration(float(first.duration))

    # sisipkan hook di depan & cta di belakang
    # segments = [hook_clip] + segments 

    segments = apply_transitions(segments, trans_dur=0.22)

    # =========================
    # CTA overlay on last segment (no blank ending)
    # =========================
    CTA_DUR = 1.4
    FADE_DUR = 0.25  # fade CTA masuk

    if segments:
        last = segments[-1]

        # freeze bg frame terakhir
        t_freeze = max(0.0, float(last.duration) - 1.0 / float(FPS))
        frame = last.get_frame(t_freeze).astype(np.uint8)
        tail_bg = ImageClip(frame).with_duration(CTA_DUR)

        # render CTA PNG (rounded box)
        cta_text, cta_sub = pick_dynamic_cta(lines)
        cta_png = os.path.join(overlay_dir, "cta.png")
        render_cta_overlay(cta_png, 720, 1280, cta_text, cta_sub)

        # RGBA -> RGB + alpha mask (JANGAN pakai _fadein_masked di sini)
        cta_ov = rgba_clip(cta_png, CTA_DUR)

        # manual blend: bg + (ov * alpha)
        def tail_frame(t):
            bg = tail_bg.get_frame(0).astype(np.float32)
            ov = cta_ov.get_frame(t).astype(np.float32)

            m = cta_ov.mask.get_frame(t)
            if m.ndim == 3:
                m = m[:, :, 0]
            m = np.clip(m.astype(np.float32), 0.0, 1.0)

            # fade-in yang benar: kalikan alpha PNG
            fade = 1.0 if FADE_DUR <= 1e-6 else min(1.0, max(0.0, t / FADE_DUR))
            m *= fade

            out = bg * (1.0 - m[:, :, None]) + ov * (m[:, :, None])
            return np.clip(out, 0, 255).astype(np.uint8)

        tail = VideoClip(tail_frame, duration=CTA_DUR)

        # audio tail = silence
        silence = AudioClip(lambda t: 0.0, duration=CTA_DUR)
        try:
            silence = silence.set_fps(44100)
        except Exception:
            pass

        tail = tail.with_audio(silence)

        segments[-1] = concatenate_videoclips([last, tail], method="compose")

    final = concatenate_videoclips(segments, method="compose")

    # =========================
    # ADD BGM (mix with voice)
    # =========================
    bgm_path = pick_bgm_path()
    if bgm_path:
        bgm = AudioFileClip(bgm_path)

        # loop bgm sepanjang durasi video
        bgm_loop = loop_audio_to_duration(bgm, float(final.duration))

        # opsional: lebih kenceng saat hook, lebih pelan saat konten
        # (kalau kamu pakai HOOK_DUR/CTA_DUR, sesuaikan angkanya)
        try:
            hook_dur = HOOK_DUR
        except Exception:
            hook_dur = 0.0

        bgm_loop = make_bgm_with_hook(
            bgm_loop,
            total_dur=float(final.duration),
            hook_dur=float(hook_dur),
            vol_hook=0.22,     # musik agak terasa di hook
            vol_normal=0.12,   # musik pelan saat voice jalan
        )

        # mix: bgm + voice final
        if final.audio is not None:
            final = final.with_audio(CompositeAudioClip([bgm_loop, final.audio]))
        else:
            final = final.with_audio(bgm_loop)

    # render quality: bitrate tinggi + preset lambat
    final.write_videofile(
        out_mp4,
        fps=FPS,
        codec="libx264",
        audio_codec="aac",
        preset="slow",
        bitrate="4500k",
        audio_bitrate="192k",
        ffmpeg_params=[
            "-pix_fmt", "yuv420p",
            "-movflags", "+faststart",
            "-profile:v", "high",
            "-level", "4.0",
        ],
    )
    return out_mp4
