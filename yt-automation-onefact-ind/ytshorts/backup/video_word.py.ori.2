def auto_hook_from_doc(doc=None, lines: List[str] = None, topic: str = "FAKTA CEPAT") -> Tuple[str, str]:
    lines = lines or []
    first = (lines[0] if lines else "").strip()

    # Seed biar konsisten per video (opsional). Kalau mau benar2 random: rng = random.Random()
    seed_key = ("|".join(lines)[:400] + "|" + topic).encode("utf-8", errors="ignore")
    seed = int(hashlib.sha1(seed_key).hexdigest()[:8], 16)
    rng = random.Random(seed)

    # kalau kalimat pertama sudah kuat, pakai itu sebagai title
    if first and len(first) <= 36:
        # pilih sub dari template bank
        _, sub = _pick_non_repeat(rng, HOOK_TEMPLATES, "hook")
        return (first.upper(), sub if sub else topic)

    # selain itu, random dari template
    t = _pick_non_repeat(rng, HOOK_TEMPLATES, "hook")
    if not t:
        return ("KAMU JARANG TAU!", topic)
    title, sub = t
    # override sub dengan topic kalau kamu mau konsisten niche:
    return (title, topic)

def pick_dynamic_cta(lines: List[str]) -> Tuple[str, str]:
    lines = lines or []
    seed_key = ("|".join(lines)[:400] + "|cta").encode("utf-8", errors="ignore")
    seed = int(hashlib.sha1(seed_key).hexdigest()[:8], 16)
    rng = random.Random(seed)

    t = _pick_non_repeat(rng, CTA_TEMPLATES, "cta")
    if not t:
        return ("FOLLOW UNTUK PART 2!", "LIKE + KOMEN FAVORITMU")
    return t

