def _wrap_lines(draw: ImageDraw.ImageDraw, text: str, font: ImageFont.FreeTypeFont, max_width: int, max_lines: int = 2):
    """
    Wrap text jadi max_lines baris berdasarkan lebar pixel.
    """
    words = (text or "").strip().split()
    if not words:
        return [""]

    lines = []
    cur = words[0]
    for w in words[1:]:
        test = cur + " " + w
        bbox = draw.textbbox((0, 0), test, font=font, stroke_width=6)
        if (bbox[2] - bbox[0]) <= max_width:
            cur = test
        else:
            lines.append(cur)
            cur = w
            if len(lines) >= max_lines - 1:
                break

    lines.append(cur)

    # kalau masih ada sisa kata dan sudah mentok, gabung di baris terakhir
    if len(lines) == max_lines and (len(words) > sum(len(l.split()) for l in lines)):
        pass

    return lines[:max_lines]


def _draw_text_box(
    img: Image.Image,
    text_lines: List[str],
    *,
    x: int,
    y: int,
    w: int,
    h: int,
    font: ImageFont.FreeTypeFont,
    fill=(255, 255, 255, 255),
    stroke_fill=(0, 0, 0, 220),
    stroke_width=4,
    align="center",
) -> None:
    draw = ImageDraw.Draw(img)
    # hitung total height
    line_heights = []
    max_w = 0
    for t in text_lines:
        bbox = draw.textbbox((0, 0), t, font=font, stroke_width=stroke_width)
        max_w = max(max_w, bbox[2] - bbox[0])
        line_heights.append(bbox[3] - bbox[1])
    total_h = sum(line_heights) + max(0, (len(text_lines) - 1) * int(font.size * 0.25))

    yy = y + (h - total_h) // 2
    for i, t in enumerate(text_lines):
        bbox = draw.textbbox((0, 0), t, font=font, stroke_width=stroke_width)
        tw = bbox[2] - bbox[0]
        th = bbox[3] - bbox[1]
        if align == "center":
            xx = x + (w - tw) // 2
        elif align == "left":
            xx = x
        else:
            xx = x + (w - tw)
        draw.text(
            (xx, yy),
            t,
            font=font,
            fill=fill,
            stroke_fill=stroke_fill,
            stroke_width=stroke_width,
        )
        yy += th + int(font.size * 0.25)

def _kb_cache_name(img_path: str, dur: float, out_size=(720, 1280), zoom_max=0.18, pan_x=120, pan_y=180, fps=30) -> str:
    key = f"{os.path.abspath(img_path)}|{dur:.3f}|{out_size}|{zoom_max}|{pan_x}|{pan_y}|{fps}"
    h = hashlib.sha1(key.encode("utf-8")).hexdigest()[:12]
    base = os.path.splitext(os.path.basename(img_path))[0]
    return f"kb_{base}_{h}.mp4"

def split_words(line: str) -> List[str]:
    line = (line or "").strip()
    if not line:
        return []
    return re.findall(r"[A-Za-z0-9À-ÿ']+|[^\sA-Za-z0-9À-ÿ']+", line, flags=re.UNICODE)


def word_durations(words: List[str], total_dur: float) -> List[float]:
    """
    Heuristik sederhana tapi stabil:
    - proporsional panjang kata
    - last word dipaksa menutup sisa (anti gap)
    """
    if not words:
        return []
    weights = []
    for w in words:
        w2 = re.sub(r"\W+", "", w)
        weights.append(max(1.0, float(len(w2) or 1)))
    s = sum(weights)
    durs = [total_dur * (w / s) for w in weights]
    # paksa last = sisa exact (anti floating drift)
    s2 = sum(durs[:-1])
    durs[-1] = max(0.02, total_dur - s2)
    return durs

def render_watermark(out_png: str, w: int, h: int, text: str, opacity: int = 160) -> None:
    img = Image.new("RGBA", (w, h), (0, 0, 0, 0))
