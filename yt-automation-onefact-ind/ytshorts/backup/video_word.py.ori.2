HOOK_TEMPLATES = [
    ("KAMU JARANG TAU!", "FAKTA CEPAT"),
    ("TAHUKAH KAMU?", "FAKTA CEPAT"),
    ("STOP SCROLL!", "DENGERIN INI"),
    ("FAKTA SINGKAT!", "CUMA 30 DETIK"),
